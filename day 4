//problem 6
//print pattern left right angle triangle 
#include <iostream>
using namespace std;
int main(){
    
    int n = 5;
    
        for(int i = 1; i <= n; i++){
            for(int j = 1; j<= n-i; j++){
            cout<<" ";
        }
        for( int k = 1; k <= i; k++){
            cout<<"*";
        }
        cout<<endl;
        }
        
    
}










