#include <iostream>
using namespace std;

int rec(int n){
    if (n < 4)
        return 1;
    return rec(n - 4) + rec(n - 1);
}
int main()
{
    int n;
    cout << "Enter length: ";
    cin >> n;
    cout << "result = "<<rec(n) ;
}








