//program 1 
//binary string without consicutive 1 
#include <iostream>
using namespace std;

void generate(string str, int n, int last)
{
    if(str.length() == n)
    {
        cout << str << endl;
        return;
    }

    generate(str + "0", n, 0);

    if(last == 0)
        generate(str + "1", n, 1);
}

int main()
{
    int n;
    cout << "Enter length: ";
    cin >> n;

    generate("", n, 0);

    return 0;
}









