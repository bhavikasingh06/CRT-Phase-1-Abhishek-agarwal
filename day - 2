#include <iostream>
using namespace std;

int main()
{
    int age;
    cin>>age;
    
    if (age>=18) {
        if (age>=50) {
            cout<<"senior citizen eligiblr for vote...";
        } else {
            cout<<"eligiblle for vote...";
        }
    }  else {
        if(age<0) {
            cout<<"enter a valid age number...";
        } else {
            cout <<"not eligible for vote";
        }
    }
    return 0;
}

   
    
    
    
   
