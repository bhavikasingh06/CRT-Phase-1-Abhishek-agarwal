//palindrome string
#include<iostream>
using namespace std;

bool isPalindrome(string str){
    int start = 0;
    int end = str.size()-1;
    while(start < end){
        if (str[start] != str [end]){
            return false;
        }
        start ++; 
        end --;
    }
    return true;
}

int main(){
    string str;
    cout<<"enter a string = ";
    cin>>str;
    
    if (isPalindrome(str)){
        cout<<"is palindrome";
    }else{
        cout<<"not palindrome";
    }
    return 0;
}














//program 2  
//binary search 
#include<iostream>
using namespace std;
int main(){
    int n;
    cout<<"enter size of array";
    cin>>n;
    
    int arr[n];
    
    cout<<"enter the sorted aaray = ";
    for(int i = 0; i < n; i++){
        cin>>arr[i];
    }
    int target;
    cout<<"enter the target element ";
    cin>>target;
    
    //binary search
    int low = 0; 
    int high = n-1;
    bool found = false;
    
    while(low<=high){
        int mid = (low + high )/2;
        
        if (arr[mid] == target){
            cout<<"element found at index = "<<mid;
            found = true;
            break;
        }else if(arr[mid] < target){
            low = mid + 1 ;
        }else{
            high = mid - 1;
        }
    }
    if(found == false){
        cout<<"element not found";
    }
    return 0;
}

























