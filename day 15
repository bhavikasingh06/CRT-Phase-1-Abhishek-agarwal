// program 1 
// reversed array
#include<iostream>
#include<stack>
using namespace std;
int main(){
    int arr[] = {10,20,30,40,50};
    int n = 5;
    
    stack<int> st;
    // java --stack<integer> st = new stack()
    
    //push the data into stack
    for(int i = 0; i < n; i++){
        st.push(arr[i]);
    }
    
    //pop data from stack and put into array
    
    for(int i = 0; i < n; i++){
        arr[i] = st.top();
        st.pop();
    }  
    
    cout<<" reverse array.. ";
        
    for(int i = 0; i < n; i++){
        cout<<arr[i]<<" ";
    }
    
    return 0;
}



