//problem 1 
//2D array 
//making of 2D array
#include <iostream>
using namespace std;

int main(){
    int arr[2][2];
    
    for(int i =0; i < 2 ; i++){
        for(int j = 0; j < 2; j++){
            cin>>arr[i][j];
        }
    }
    
    cout<<"here is ur 2D array"<<"\n";
    for(int i =0; i < 2 ;i++){
        for(int j = 0; j < 2; j++){
            cout<<arr[i][j]<<" ";
        }
        cout<<"\n";
    }
    return 0;
}













//problem 2  
//sum of elements of 2d array

#include <iostream>
using namespace std;

int main(){
    int arr[2][2];
    int sum = 0;
    
    for(int i =0; i < 2 ; i++){
        for(int j = 0; j < 2; j++){
            cin>>arr[i][j];
            sum = sum + arr[i][j];
        }
    }
    cout<<"summ of elements are = "<<sum<<"\n";
}















//problem 3   
//search of elements in 2d array

#include <iostream>
using namespace std;

int main(){
    int arr[2][2] = { {10,20},
                     {30,40} };
    
    int searchElement;
    cin>>searchElement;
    
    for(int i =0; i < 2 ; i++){
        for(int j = 0; j < 2; j++){
            if(arr[i][j] == searchElement){
                cout<<i<<" "<<j;
                return 0;
            }
        }
    }
    cout<<"element not found.... ";
}






